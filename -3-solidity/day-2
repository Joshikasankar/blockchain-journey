pragma solidity ^0.8.0;

contract reverseNumbers {
    uint public n = 12345;

    function reverse() public pure returns(uint) {

        uint temp = 12345;
        uint split = 0;

        while (temp != 0) {
            uint rem = temp % 10;
            split = split * 10 + rem;
            temp = temp / 10;
        }

        return split;
    }
}
